<idea-plugin>
    <id>com.tabgroups.intellij-tab-groups-java</id>
    <name>Tab Groups</name>
    <vendor>tabgroups</vendor>
    <version>1.0.0</version>
    <description><![CDATA[
        Organizes editor tabs based on user-defined grouping rules with regex matching.
        Right-click any editor tab and select "Group and Sort Tabs" to sort open tabs by your configured groups.
    ]]></description>

    <!-- since-build="251" = 2025.1, no until-build = compatible with all future versions -->
    <idea-version since-build="251"/>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Settings/Preferences panel -->
        <projectConfigurable
                parentId="tools"
                instance="com.diakovidis.tabgroups.settings.TabGroupsConfigurable"
                id="com.diakovidis.tabgroups.settings.TabGroupsConfigurable"
                displayName="Tab Groups"/>
    </extensions>

    <actions>
        <!-- Action in the editor tab popup menu -->
        <action id="com.diakovidis.tabgroups.action.ReorderTabsAction"
                class="com.diakovidis.tabgroups.action.ReorderTabsAction"
                text="Group and Sort Tabs"
                description="Reorder open editor tabs according to Tab Groups rules">
            <add-to-group group-id="EditorTabPopupMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>

